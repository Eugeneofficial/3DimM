{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "plugins": ["react"],
  "settings": {
    "react": { "version": "detect" }
  },
  "rules": {
    "no-unused-vars": "off",
    "no-console": "off",
    "react/react-in-jsx-scope": "off",
    "react/jsx-key": "error"
  }
}
