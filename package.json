{
  "name": "3dimm",
  "version": "1.0.0",
  "main": "electron/main.js",
  "description": "Universal Video Downloader — YouTube, TikTok, Twitter, m3u8 and 1000+ sites",
  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install && cd .. && npm install",
    "server": "cd server && npm start",
    "client": "cd client && npm run dev",
    "dev": "npm run server & npm run client",
    "dev:electron": "set NODE_ENV=development && cd client && npm run dev & npm run start:electron",
    "build:client": "cd client && npm run build",
    "start:electron": "electron .",
    "lint": "eslint client/src/ shared/",
    "lint:fix": "eslint client/src/ shared/ --fix",
    "format": "prettier --write \"client/src/**/*.{js,jsx}\" \"shared/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:win": "npm run build:client && electron-builder --win",
    "build:mac": "npm run build:client && electron-builder --mac",
    "build:linux": "npm run build:client && electron-builder --linux"
  },
  "build": {
    "appId": "com.3dimm.app",
    "productName": "3DimM",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "shared/**/*",
      "client/dist/**/*",
      "node_modules/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.md,*.markdown,*.log,*.ts,*.flow,*.coffee}",
      "!**/.bin"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!**/node_modules/**",
          "!**/package-lock.json",
          "!**/downloads/**"
        ]
      },
      {
        "from": "node_modules/ffmpeg-static",
        "to": "ffmpeg",
        "filter": [
          "**/*",
          "!**/*.js",
          "!**/*.json",
          "!**/*.md"
        ]
      },
      {
        "from": "icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.0",
    "prettier": "^3.2.0",
    "vitest": "^1.6.0"
  }
}
